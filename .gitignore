# v0.2: tests/fixtures/* is closed by default. Only the synthetic
# short.mp3 + its expected.json are whitelisted; everything else stays
# blocked. Adding a new fixture requires a security review per HANDOFF.
tests/fixtures/*
!tests/fixtures/short.mp3
!tests/fixtures/short.expected.json
