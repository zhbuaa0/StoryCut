# Copy this file to .env locally. Never commit .env.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra
PORT=4173

# v0.2 — local media pipeline (all optional; sensible defaults below)
# Override the upload size cap. Default: 524288000 (500 MB).
STORYCUT_MAX_UPLOAD_BYTES=
# Override the MLX Whisper model repo id. Default: mlx-community/whisper-small-mlx
# (note the trailing "-mlx" — without it the repo does not exist on HF).
STORYCUT_WHISPER_MODEL=
# Override where uploaded media + cached transcripts live. Default: <repo>/.work
STORYCUT_WORK_DIR=

# P1 — speaker diarization. Token is read server-side only, never sent to browser.
HF_TOKEN=
